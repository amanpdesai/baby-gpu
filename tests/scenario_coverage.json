        "tb/unit/tb_load_store_unit.sv",
        "tb/integration/tb_programmable_core_store16_framebuffer.sv",
        "tb/integration/tb_gpu_core_command_store16_kernel.sv"
      ],
      "kernels": [
        "tests/kernels/store16_2a5b_zero.kgpu",
        "tests/kernels/store16_arg_linear_4c3d.kgpu",
