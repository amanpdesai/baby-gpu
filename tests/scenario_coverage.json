{
  "version": 1,
  "scenarios": [
    {
      "id": "command_wait_idle_barrier",
      "description": "WAIT_IDLE stalls the command stream until backend work is idle.",
      "tests": [
        "tb/unit/tb_command_fifo.sv",
        "tb/unit/tb_command_processor.sv",
        "tb/integration/tb_gpu_core_command_lifecycle.sv"
      ],
      "formal": [
        "formal/scripts/command_fifo.sby"
      ]
    },
    {
      "id": "command_malformed_packets",
      "description": "Malformed command packets set sticky errors and do not launch illegal work.",
      "tests": [
        "tb/unit/tb_command_processor.sv",
        "tb/integration/tb_gpu_core_command_launch_invalid.sv"
      ]
    },
    {
      "id": "command_launch_latches_abi",
      "description": "LAUNCH_KERNEL latches launch ABI registers and exposes them to kernels.",
      "tests": [
        "tb/unit/tb_register_file.sv",
        "tb/unit/tb_command_processor.sv",
        "tb/integration/tb_gpu_core_command_program_base.sv",
        "tb/integration/tb_gpu_core_command_launch_snapshot.sv",
        "tb/integration/tb_gpu_core_command_grid_snapshot.sv",
        "tb/integration/tb_gpu_core_command_program_base_snapshot.sv"
      ],
      "kernels": [
        "tests/kernels/launch_arg_snapshot_store16.kgpu",
        "tests/kernels/grid_snapshot_gradient.kgpu",
        "tests/kernels/program_base_snapshot_new.kgpu",
        "tests/kernels/program_base_snapshot_old.kgpu"
      ],
      "formal": [
        "formal/scripts/register_file.sby"
      ]
    },
    {
      "id": "command_soft_reset_recovery",
      "description": "Host-visible soft reset clears recoverable fault state after a command-driven fault.",
      "tests": [
        "tb/integration/tb_gpu_core_command_store16_fault.sv",
        "tb/integration/tb_gpu_core_command_active_reset.sv"
      ],
      "kernels": [
        "tests/kernels/store16_fault_odd.kgpu"
      ]
    },
    {
      "id": "vector_add_kernel",
      "description": "Kernel launch, global loads, ALU add, tail lanes, and global stores for vector add.",
      "tests": [
        "tb/unit/tb_lane_register_file.sv",
        "tb/unit/tb_simd_alu.sv",
        "tb/unit/tb_simd_core_basic.sv",
        "tb/unit/tb_work_scheduler.sv",
        "tb/integration/tb_programmable_core_vector_add.sv",
        "tb/integration/tb_gpu_core_command_vector_add.sv"
      ],
      "kernels": [
        "tests/kernels/vector_add.kgpu",
        "tests/kernels/programmable_vector_add_direct.kgpu"
      ],
      "formal": [
        "formal/scripts/lane_register_file.sby",
        "formal/scripts/simd_alu.sby",
        "formal/scripts/work_scheduler.sby",
        "formal/scripts/work_scheduler_sequence.sby"
      ]
    },
    {
      "id": "framebuffer_gradient_kernel",
      "description": "2D global IDs, framebuffer convention, RGB565 packing, and STORE16 output.",
      "tests": [
        "tb/integration/tb_programmable_core_framebuffer_gradient.sv",
        "tb/integration/tb_gpu_core_command_framebuffer_gradient.sv"
      ],
      "kernels": [
        "tests/kernels/framebuffer_gradient.kgpu"
      ]
    },
    {
