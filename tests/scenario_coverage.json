      "description": "Predicated bounded-fill kernels update only pixels inside the requested rectangle.",
      "tests": [
        "tb/integration/tb_programmable_core_bounded_fill.sv",
        "tb/integration/tb_programmable_core_offset_fill.sv"
      ],
      "kernels": [
        "tests/kernels/bounded_fill_3x2_04d2.kgpu",
        "tests/kernels/offset_fill_1x1_at_1_1_0a5c.kgpu"
      ]
    },
    {
      "id": "branch_control",
      "description": "Convergent branches, backward offsets, untaken branches, and R0 predicates.",
      "tests": [
        "tb/integration/tb_programmable_core_branch_control.sv"
      ],
      "kernels": [
        "tests/kernels/branch_backward_loop.kgpu",
        "tests/kernels/branch_divergent_lane_id.kgpu",
        "tests/kernels/branch_not_taken.kgpu",
        "tests/kernels/branch_r0_never_taken.kgpu",
        "tests/kernels/branch_taken.kgpu"
