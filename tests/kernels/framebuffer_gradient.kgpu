# framebuffer[y][x] = rgb565-like test value 0x0060 + x + (y * 16)

MOVSR R1, GLOBAL_ID_Y
MOVSR R2, FRAMEBUFFER_WIDTH
MUL   R3, R1, R2
MOVSR R4, GLOBAL_ID_X
ADD   R3, R3, R4
MOVI  R5, 2
MUL   R3, R3, R5
MOVSR R6, FRAMEBUFFER_BASE
ADD   R7, R6, R3

MOVI  R8, 16
MUL   R1, R1, R8
MOVI  R8, 0x60
ADD   R8, R8, R4
ADD   R8, R8, R1
STORE16 [R7 + 0], R8
END
