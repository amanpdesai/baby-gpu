# Fills a 3x2 rectangle from the origin with 0x04d2 halfwords.
MOVSR R1, GLOBAL_ID_Y
MOVSR R2, FRAMEBUFFER_WIDTH
MUL R3, R1, R2
MOVSR R4, GLOBAL_ID_X
ADD R3, R3, R4
MOVI R5, 2
MUL R3, R3, R5
MOVSR R6, FRAMEBUFFER_BASE
ADD R7, R6, R3
MOVI R8, 0x04d2
MOVI R9, 3
CMP.LTU R10, R4, R9
MOVI R11, 2
CMP.LTU R12, R1, R11
AND R13, R10, R12
PSTORE16 [R7 + 0], R8, R13
END
