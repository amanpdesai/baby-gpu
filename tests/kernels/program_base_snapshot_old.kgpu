# PROGRAM_BASE snapshot test old program.
# Initial load is held while PROGRAM_BASE is rewritten. If launch state is
# snapshotted correctly, this old program continues and writes OLD_COLOR.

MOVI  R1, 0
LOAD  R2, [R1 + 0]
MOVSR R3, LINEAR_GLOBAL_ID
MOVI  R4, 2
MUL   R3, R3, R4
MOVI  R5, 0x80
ADD   R5, R5, R3
MOVI  R6, 0x2468
STORE16 [R5 + 0], R6
END
