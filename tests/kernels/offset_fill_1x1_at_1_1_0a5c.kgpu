# Fills a 1x1 rectangle at x=1, y=1 with 0x0a5c halfwords.
MOVSR R1, GLOBAL_ID_Y
MOVSR R2, FRAMEBUFFER_WIDTH
MUL R3, R1, R2
MOVSR R4, GLOBAL_ID_X
ADD R3, R3, R4
MOVI R5, 2
MUL R3, R3, R5
MOVSR R6, FRAMEBUFFER_BASE
ADD R7, R6, R3
MOVI R8, 0x0a5c
MOVI R9, 1
CMP.GEU R10, R4, R9
MOVI R9, 2
CMP.LTU R11, R4, R9
AND R10, R10, R11
MOVI R9, 1
CMP.GEU R11, R1, R9
AND R10, R10, R11
MOVI R9, 2
CMP.LTU R11, R1, R9
AND R10, R10, R11
PSTORE16 [R7 + 0], R8, R10
END
