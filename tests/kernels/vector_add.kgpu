# C[i] = A[i] + B[i]
# Argument block:
#   [ARG_BASE + 0]  = A base address
#   [ARG_BASE + 4]  = B base address
#   [ARG_BASE + 8]  = C base address
#   [ARG_BASE + 12] = element count, unused by this grid-sized fixture

MOVSR R1, LINEAR_GLOBAL_ID
MOVI  R2, 4
MUL   R1, R1, R2

MOVSR R8, ARG_BASE
LOAD  R3, [R8 + 0]
LOAD  R4, [R8 + 4]
LOAD  R10, [R8 + 8]
LOAD  R11, [R8 + 12]

ADD   R5, R3, R1
LOAD  R6, [R5 + 0]
ADD   R5, R4, R1
LOAD  R7, [R5 + 0]
ADD   R9, R6, R7
ADD   R5, R10, R1
STORE [R5 + 0], R9
END
